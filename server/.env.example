# Copy to `.env` for local dev (`.env` is gitignored). On Deno Deploy these are
# set as dashboard secrets / via `deno deploy env`, NOT committed.

# The only phone allowed to authenticate and trigger payouts (William's).
# International or 0-prefixed UK both work (the server normalises 0… -> +44…).
AUTHORIZED_PHONE=

# Prelude (SMS one-time-code) API token.
PRELUDE_API_KEY=

# Wise — pays the real money out. Profile id, the target recipient account id,
# and an API key with transfer permissions.
# Personal Wise accounts can't fund transfers via the API (PSD2/SCA), so the server
# only creates the transfers — fund them once by hand in the Wise app/website.
WISE_API_KEY=
WISE_PROFILE_ID=
WISE_TARGET_ACCOUNT=

# ntfy push topic — you get a "go fund this transfer" alert the moment one is set
# up. Subscribe to it in the ntfy app (https://ntfy.sh/<topic>). Treat it like a
# secret: anyone who knows the topic can read the alerts. Leave blank to disable.
NTFY_TOPIC=

# Local-only: path to the on-disk KV file for dev. Leave UNSET on Deno Deploy
# (managed KV is auto-provisioned there). Lets clear-kv.ts hit the same store.
# KV_PATH=./local-kv.sqlite3
